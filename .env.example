# Copy to .env and fill in your keys.
GROQ_API_KEY=your_groq_api_key
PEXELS_API_KEY=your_pexels_api_key

# Optional: Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: path to background music for reels (MP3/WAV). If unset, reel has no audio track.
# REEL_MUSIC_PATH=C:\music\travel_bgm.mp3

# Reel: number of still images to stitch (default 5) and total duration in seconds (default 15)
# REEL_FRAME_COUNT=5
# REEL_TOTAL_SECONDS=15
# Reels export size (9:16 portrait for Instagram)
# REEL_WIDTH=1080
# REEL_HEIGHT=1920
# Text on the “info” pill burned into the MP4 (empty = no overlay)
# REEL_BRAND_TEXT=budgetwing.com

# Optional: project root override for output (default: ./output)
# OUTPUT_DIR=./output

# Optional: FFmpeg — folder (with bin/ffmpeg.exe inside) or full path to ffmpeg.exe
# Windows example (unzipped build):
# FFMPEG_PATH=R:\projects\ffmpeg-8.1
