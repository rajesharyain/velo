# Copy to .env and fill in your keys.
GROQ_API_KEY=your_groq_api_key
PEXELS_API_KEY=your_pexels_api_key

# Optional: Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: path to background music for reels (MP3/WAV). If unset, reel has no audio track.
# REEL_MUSIC_PATH=C:\music\travel_bgm.mp3

# Reel: number of still images (default 5). Length ≈ REEL_FRAME_COUNT × REEL_SECONDS_PER_SLIDE (clamped).
# REEL_FRAME_COUNT=5
# REEL_SECONDS_PER_SLIDE=2.9
# REEL_MIN_TOTAL_SECONDS=8
# REEL_MAX_TOTAL_SECONDS=78
# REEL_XFADE_MIN_SECONDS=0.42
# REEL_XFADE_MAX_SECONDS=0.95
# REEL_XFADE_SEGMENT_RATIO=0.34
# Legacy soft cap (still in config for other uses)
# REEL_TOTAL_SECONDS=15
# InstaPost FFmpeg reel length range when not passed explicitly
# INSTAPOST_REEL_MIN_SECONDS=22
# INSTAPOST_REEL_MAX_SECONDS=52
# Carousel text: larger fonts + panel behind text block
# CAROUSEL_TITLE_FONT_SCALE=1.14
# CAROUSEL_BODY_FONT_SCALE=1.10
# CAROUSEL_TEXT_PANEL_ALPHA=218
# Reels export size (9:16 portrait for Instagram)
# REEL_WIDTH=1080
# REEL_HEIGHT=1920
# Footer URL below caption if not already in slide text (empty = off)
# REEL_BRAND_TEXT=budgetwing.com

# Carousel: last slide line + shift text up (0.1 = 10% of slide height) for clearer captions
# CAROUSEL_CLOSING_TEXT=Explore more\nvisit budgetwing.com\nfor cheap flights.
# CAROUSEL_TEXT_BIAS_UP_RATIO=0
# Reels text layout (safe zones + bands). Optional tuning:
# REEL_TEXT_SAFE_TOP_RATIO=0.055
# REEL_TEXT_SAFE_BOTTOM_RATIO=0.20
# REEL_PRIMARY_ZONE_END_RATIO=0.44
# REEL_CAPTION_ZONE_START_RATIO=0.48
# REEL_TEXT_SIDE_INSET_RATIO=0.93
# On-slide brand link color (RGB) and optional Pexels min photo long edge (0 = any)
# BRAND_DOMAIN_R=64
# BRAND_DOMAIN_G=196
# BRAND_DOMAIN_B=255
# PEXELS_MIN_PHOTO_EDGE=1400

# Optional: project root override for output (default: ./output)
# OUTPUT_DIR=./output

# Optional: FFmpeg — folder (with bin/ffmpeg.exe inside) or full path to ffmpeg.exe
# Windows example (unzipped build):
# FFMPEG_PATH=R:\projects\ffmpeg-8.1
