# ─────────────────────────────────────────────────────────────────────────────
# Velo Automation Config
# Copy this file to velo.config.env and fill in your values.
# velo.config.env is gitignored — safe to store real paths here.
# ─────────────────────────────────────────────────────────────────────────────

# Absolute path to your Excel queue file (reels-queue.xlsx).
# The file must have columns: destination, status (pending/done), tags (optional).
# Example:
EXCEL_PATH=/Users/yourname/Documents/reels-queue.xlsx

# How many workflow runs to trigger per scheduled firing (default: 1).
# Set to 2 if you want two rows processed each time the schedule fires.
TRIGGER_COUNT=1

# Gap in seconds between multiple triggers (only applies when TRIGGER_COUNT > 1).
TRIGGER_GAP_SECONDS=15

# Velo project directory (auto-set by install_schedule.sh — do not edit manually).
VELO_DIR=/Users/ravi/Documents/Apps/velo
